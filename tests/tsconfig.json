{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "declaration": true,
    "sourceMap": true,
    "outDir": "../.tests",
    "target": "esnext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../src/*"]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "**/*.test.ts"
  ],
  "references": [
    {
      "path": "../src"
    }
  ]
}
