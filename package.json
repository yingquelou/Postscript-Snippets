{
	"name": "postscriptsnippets",
	"displayName": "PostScript Programming Language",
	"publisher": "yingquelou",
	"description": "PostScript GhostScript",
	"version": "1.1.0",
	"engines": {
		"vscode": "^1.70.3"
	},
	"activationEvents": [
		"onDebugResolve:postscript"
	],
	"categories": [
		"Snippets",
		"Programming Languages",
		"Debuggers"
	],
	"main": "out/extension.js",
	"contributes": {
		"configuration": [
			{
				"title": "PostScript Configuration",
				"properties": {
					"postscript.interpreter.executable": {
						"description": "PostScript interpreter executable path",
						"type": "string",
						"default": "gs"
					}
				}
			}
		],
		"configurationDefaults": {
			"postscript.interpreter.executable": "gs"
		},
		"grammars": [
			{
				"language": "postscript",
				"scopeName": "source.postscript",
				"path": "./language/postscript.tmLanguage.json"
			}
		],
		"breakpoints": [
			{
				"language": "postscript"
			}
		],
		"languages": [
			{
				"id": "postscript",
				"extensions": [
					".ps",
					".eps"
				],
				"aliases": [
					"PostScript",
					"GhostScript"
				],
				"configuration": "./language/language-configuration.json"
			}
		],
		"debuggers": [
			{
				"type": "postscript",
				"label": "PostScript (Ghostscript) Debugger",
				"program": "./out/debugger/debugAdapter.js",
				"runtime": "node",
				"languages": [
					"postscript"
				],
				"configurationAttributes": {
					"launch": {
						"properties": {
							"program": {
								"type": "string",
								"description": "PostScript file to run"
							},
							"ghostscriptPath": {
								"type": "string",
								"description": "Ghostscript executable path. If not set, uses the extension setting or platform default."
							},
							"cwd": {
								"type": "string",
								"description": "Working directory for the interpreter.",
								"default": "${workspaceFolder}"
							},
							"stopOnEntry": {
								"type": "boolean",
								"default": false,
								"description": "Whether to stop at the entry point when starting debugging. Default: false."
							},
							"args": {
								"type": "array",
								"description": "Additional arguments passed to Ghostscript.",
								"items": {
									"type": "string"
								}
							}
						}
					}
				},
				"configurationSnippets": [
					{
						"label": "Launch PostScript",
						"body": {
							"type": "postscript",
							"request": "launch",
							"name": "Launch PostScript",
							"program": "${file}",
							"cwd": "${workspaceFolder}"
						}
					}
				]
			}
		]
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/yingquelou/Postscript-Snippets.git"
	},
	"scripts": {
		"test": "node .tests/debugAdapter.test.js",
		"pretest": "tsc -b tests",
		"build:scripts": "tsc -b scripts",
		"build:snippets": "node .scripts/snippetsGenerator.js",
		"prebuild": "npm run build:scripts",
		"build": "node .scripts/esbuild.js",
		"postbuild": "npm run build:snippets",
		"prepackage": "npm run build",
		"prepublish": "npm run build",
		"postpackage": "node .scripts/restore.js",
		"postpublish": "node .scripts/restore.js",
		"preclean": "npm run build:scripts",
		"clean": "node .scripts/clean.js out .snippets .tests .scripts",
		"watch:scripts": "tsc -b scripts --watch",
		"prewatch": "npm run build",
		"watch": "node .scripts/esbuild.js --watch",
		"typecheck": "tsc --noEmit -p . && tsc --noEmit -p scripts",
		"package": "vsce package",
		"publish": "vsce publish"
	},
	"devDependencies": {
		"@vscode/debugadapter": "^1.68.0",
		"@vscode/debugprotocol": "^1.68.0",
		"chevrotain": "10.5.0",
		"vscode-languageclient": "^8.0.0",
		"vscode-languageserver": "^8.0.0",
		"vscode-languageserver-textdocument": "^1.0.0",
		"@types/node": "^24.10.1",
		"@types/vscode": "^1.66.0",
		"@vscode/vsce": "^3.9.1",
		"esbuild": "^0.28.0",
		"marked": "^17.0.1",
		"typescript": "^6.0.3"
	}
}