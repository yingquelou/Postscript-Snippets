{
	"name": "postscriptsnippets",
	"displayName": "PostScript Programming Language",
	"publisher": "yingquelou",
	"description": "PostScript GhostScript",
	"version": "1.0.9",
	"engines": {
		"vscode": "^1.70.3"
	},
	"activationEvents": [],
	"categories": [
		"Snippets",
		"Programming Languages",
		"Debuggers"
	],
	"main": "dist/extension.js",
	"contributes": {
		"configuration": [
			{
				"title": "PostScript Configuration",
				"properties": {
					"postscript.interpreter.executable": {
						"description": "PostScript interpreter executable path",
						"type": "string",
						"default": "gs"
					}
				}
			}
		],
		"configurationDefaults": {
			"postscript.interpreter.executable": "gs"
		},
		"grammars": [
			{
				"language": "postscript",
				"scopeName": "source.postscript",
				"path": "./language/postscript.tmLanguage.json"
			}
		],
		"breakpoints": [
			{
				"language": "postscript"
			}
		],
		"languages": [
			{
				"id": "postscript",
				"extensions": [
					".ps",
					".eps"
				],
				"aliases": [
					"PostScript",
					"GhostScript",
					"OptScript"
				],
				"configuration": "./language/language-configuration.json"
			}
		],
		"debuggers": [
			{
				"type": "postscript",
				"label": "PostScript (Ghostscript) Debugger",
				"program": "./dist/debugAdapter.js",
				"runtime": "node",
				"languages": [
					"postscript"
				],
				"configurationAttributes": {
					"launch": {
						"properties": {
							"program": {
								"type": "string",
								"description": "PostScript file to run"
							},
							"ghostscriptPath": {
								"type": "string",
								"description": "Path to Interpreter executable (eg. gs/gswin32c/gswin64c). If not set, uses postscript.interpreter.executable setting or platform default."
							},
							"cwd": {
								"type": "string",
								"description": "Interpreter working directory"
							},
							"args": {
								"type": "array",
								"description": "Arguments to Interpreter",
								"items": {
									"type": "string"
								}
							}
						}
					}
				},
				"configurationSnippets": [
					{
						"label": "Launch PostScript",
						"body": {
							"type": "postscript",
							"request": "launch",
							"name": "Launch PostScript",
							"program": "${file}",
							"cwd": "${workspaceFolder}"
						}
					}
				]
			}
		]
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/yingquelou/Postscript-Snippets.git"
	},
	"scripts": {
		"build:scripts": "esbuild scripts/snippetsGenerator.ts scripts/esbuild.ts --bundle --platform=node --outdir=dist/scripts --outbase=scripts --format=cjs --external:esbuild",
		"snippets": "node dist/scripts/snippetsGenerator.js",
		"bundle": "node dist/scripts/esbuild.js",
		"build": "npm run build:scripts && npm run snippets && npm run bundle",
		"watch": "npm run build:scripts && node dist/scripts/esbuild.js --watch",
		"typecheck": "tsc --noEmit -p . && tsc --noEmit -p tsconfig.scripts.json",
		"postpackage": "node scripts/restore.js",
		"postpublish": "node scripts/restore.js",
		"clean": "node scripts/clean.js",
		"prepackage": "npm run build",
		"prepublish": "npm run build",
		"package": "vsce package",
		"publish": "vsce publish"
	},
	"dependencies": {
		"@vscode/debugadapter": "^1.68.0",
		"@vscode/debugprotocol": "^1.68.0",
		"chevrotain": "10.5.0",
		"vscode-languageclient": "^8.0.0",
		"vscode-languageserver": "^8.0.0",
		"vscode-languageserver-textdocument": "^1.0.0"
	},
	"devDependencies": {
		"@types/node": "^24.10.1",
		"@types/vscode": "^1.66.0",
		"@vscode/vsce": "^3.9.1",
		"esbuild": "^0.28.0",
		"marked": "^17.0.1",
		"typescript": "^6.0.3"
	}
}