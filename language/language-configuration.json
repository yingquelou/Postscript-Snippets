{
    "comments": {
        "lineComment": "%"
    },
    "brackets": [
        ["(", ")"],
        ["[", "]"],
        ["{", "}"],
        ["<", ">"],
        ["<~", "~>"],
        ["<<", ">>"]
    ],
    "autoClosingPairs": [
        ["(", ")"],
        ["[", "]"],
        ["{", "}"],
        ["<", ">"],
        ["<~", "~>"],
        ["<<", ">>"]
    ],
    "surroundingPairs": [
        ["(", ")"],
        ["[", "]"],
        ["{", "}"],
        ["<~", "~>"],
        ["<<", ">>"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^\\s*(\\[|\\{|<<)\\s*$",
        "decreaseIndentPattern": "^\\s*(\\]|\\}|>>)\\s*$"
    },
    "wordPattern": "/{1,2}[^\\s\\[\\]{}<>/%()#]*|[^\\s\\[\\]{}<>/%()#0-9][^\\s\\[\\]{}<>/%()#]*"
}